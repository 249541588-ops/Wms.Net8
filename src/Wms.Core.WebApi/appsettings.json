      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "localhost;127.0.0.1",
  "App": {
    "BaseUrl": "http://localhost:3100/"
  },
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=127.0.0.1;Initial Catalog=WmsDb;Persist Security Info=False;User ID=sa;Password=123456a;Connect Timeout=30;TrustServerCertificate=True;",
    "CtaskConnection": "Data Source=127.0.0.1;Initial Catalog=ctask;Persist Security Info=False;User ID=sa;Password=123456a;Connect Timeout=30;TrustServerCertificate=True;",
    "LogConnection": "Data Source=127.0.0.1;Initial Catalog=WmsLogsDb;Persist Security Info=False;User ID=sa;Password=123456a;Connect Timeout=30;TrustServerCertificate=True;"
  },
  "Wcs": {
    "Mode": "Database",
    "Endpoint": ""
  },
  "Mes": {
    "Enable": false,
    "Endpoint": "",
    "TimeoutSeconds": 10
  },
  "HangKe": {
    "Enable": false,
    "Endpoint": "",
    "TimeoutSeconds": 10,
    "UserName": "TSGX2ZZ",
    "PassWord": "ZZ@123"
  },
  "Jwt": {
    "Issuer": "Wms.Core.WebApi",
    "Audience": "Wms.Client",
    "SecretKey": "CHANGE_ME_USE_USER_SECRETS_OR_ENVIRONMENT_VARIABLE_32_CHARS_MIN",
    "ExpirationMinutes": 60,
    "RefreshExpirationDays": 7
  },
  "Security": {
    "RequireHttps": false,
    "AllowedOrigins": [      
      "http://127.0.0.1:3099",
      "http://localhost:3099"
    ]
  },
  "RateLimit": {
    "EnableRateLimiting": true,
    "GlobalLimit": 600,
    "GlobalSlidingWindow": 60,
    "PerClientLimit": 200,
    "PerClientSlidingWindow": 60,
    "EndpointRules": [
      {
        "Endpoint": "api/auth/login",
        "Method": "POST",
        "Period": 60,
        "Limit": 10
      },
      {
        "Endpoint": "api/excel",
        "Method": "*",
        "Period": 300,
        "Limit": 5
      }
    ]
  },
  "AuditLog": {
    "EnableAuditLogging": true,
    "LogDataAccessForEntities": [
      "Material",
      "Stock",
      "User",
      "Role"
    ]
  },
  "Redis": {
    "Enabled": false,
    "ConnectionString": "localhost:6789",
    "InstanceName": "Wms:",
    "DefaultExpirationMinutes": 30
  },
  "HealthChecks": {
    "Enabled": true,
    "DiskSpace": {
      "Enabled": true,
      "MinFreeSpaceGb": 5,
      "MinFreeSpacePercent": 10
    },
    "Redis": {
      "Enabled": true,
      "MaxResponseTimeMs": 1000
    },
    "Wcs": {
      "Enabled": true,
      "TimeoutSeconds": 5,
      "Mode": "Database",
      "Endpoint": ""
    }
  },
  "Upload": {
    "BasePath": "",
    "MaxImageSizeMB": 5,
    "MaxExcelSizeMB": 10
  },
  "Wms": {
    "EventBus": {
      "Type": "Wms.Core.Domain.Events.DefaultEventBus, Wms.Core.Domain"
    },
    "TrayCode": {
      "Gw": "HC8",
      "Hc": "FR8",
      "Cw": "HC8"
    }
  },
  "DataCleanup": {
    "RetentionDays": {
      "ArchivedTasks": 90,
      "ArchivedUnitloads": 90,
      "ArchivedUnitloadItems": 90,
      "ArchivedUnitloadItemDetails": 90,
      "UnitloadOps": 60,
      "UploadMesInfo": 60,
      "SystemLogs": 30,
      "LocationOps": 60,
      "BatteryCells": 90,
      "InterfaceLogs": 30,
      "WcsTasks": 30,
      "Flows": 90,
      "BatteryOps": 90,
      "FlowNodeLogs": 60,
      "FlowInstances": 60,
      "RefreshTokens": 30
    }
  },
  "ReportSettings": {
    "ExportDirectory": "./exports",
    "ExportFileRetentionDays": 7,
    "ExportBatchSize": 5000,
    "CustomQueryTimeoutSeconds": 30,
    "MaxExportFileSizeMB": 500
  }
}
