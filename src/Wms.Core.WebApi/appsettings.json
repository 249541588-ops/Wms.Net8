{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=YOUR_SQL_SERVER;Initial Catalog=WmsDb;Persist Security Info=True;User ID=YOUR_DB_USER;Password=YOUR_DB_PASSWORD;Connect Timeout=500;TrustServerCertificate=True;MultipleActiveResultSets=True;",
    "CtaskConnection": "Data Source=YOUR_SQL_SERVER;Initial Catalog=ctask;Persist Security Info=True;User ID=YOUR_DB_USER;Password=YOUR_DB_PASSWORD;Connect Timeout=30;TrustServerCertificate=True;",
    "LogConnection": "Data Source=YOUR_SQL_SERVER;Initial Catalog=WmsLogsDb;Persist Security Info=True;User ID=YOUR_DB_USER;Password=YOUR_DB_PASSWORD;Connect Timeout=500;TrustServerCertificate=True;"
  },
  "Wcs": {
    "Mode": "Database",
    "Endpoint": ""
  },
  "Jwt": {
    "Issuer": "Wms.Core.WebApi",
    "Audience": "Wms.Client",
    "SecretKey": "CHANGE_ME_USE_USER_SECRETS_OR_ENVIRONMENT_VARIABLE_32_CHARS_MIN",
    "ExpirationMinutes": 60,
    "RefreshExpirationDays": 7
  },
  "Security": {
    "RequireHttps": false,
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:4200",
      "http://localhost:5000",
      "http://127.0.0.1:51479",
      "http://127.0.0.1:51480"
    ]
  },
  "RateLimit": {
    "EnableRateLimiting": true,
    "GlobalLimit": 600,
    "GlobalSlidingWindow": 60,
    "PerClientLimit": 200,
    "PerClientSlidingWindow": 60,
    "EndpointRules": [
      {
        "Endpoint": "api/auth/login",
        "Method": "POST",
        "Period": 60,
        "Limit": 10
      },
      {
        "Endpoint": "api/excel",
        "Method": "*",
        "Period": 300,
        "Limit": 5
      }
    ]
  },
  "AuditLog": {
    "EnableAuditLogging": true,
    "LogDataAccessForEntities": [
      "Material",
      "Stock",
      "User",
      "Role"
    ]
  },
  "Redis": {
    "Enabled": false,
    "ConnectionString": "localhost:6789",
    "InstanceName": "Wms:",
    "DefaultExpirationMinutes": 30
  },
  "HealthChecks": {
    "Enabled": true,
    "DiskSpace": {
      "Enabled": true,
      "MinFreeSpaceGb": 5,
      "MinFreeSpacePercent": 10
    },
    "Redis": {
      "Enabled": true,
      "MaxResponseTimeMs": 1000
    },
    "Wcs": {
      "Enabled": true,
      "TimeoutSeconds": 5,
      "Mode": "Database",
      "Endpoint": ""
    },
  "Upload": {
    "BasePath": "",
    "MaxImageSizeMB": 5,
    "MaxExcelSizeMB": 10
  },
  "Wms": {
    "EventBus": {
      "Type": "Wms.Core.Domain.Events.DefaultEventBus, Wms.Core.Domain"
    },
    "TrayCode": {
      "Gw": "HC8",
      "Hc": "FR8",
      "Cw": "HC8"
    }
    }
  }
}
