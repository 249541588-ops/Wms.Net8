<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true"
      throwExceptions="false"
      internalLogLevel="Warn"
      internalLogFile="logs/internal-nlog.log">

  <!-- 定义变量 -->
  <variable name="logDirectory" value="logs"/>
  <variable name="layoutPattern"
            value="${longdate}|${level:uppercase=true}|${logger:shortName=true}|${message}${onexception:${newline}EXCEPTION\: ${exception:format=ToString,Data}}"/>

  <!-- 定义目标 -->
  <targets>
    <!-- 控制台输出 - 带颜色高亮 -->
    <target xsi:type="ColoredConsole"
            name="console"
            layout="${time} [${level:uppercase=true:padding=-5}] ${logger:shortName=true}: ${message}${onexception:${newline}EXCEPTION\: ${exception:format=ToString}}"
            detectConsoleAvailable="true">

      <highlight-row foregroundColor="NoChange" backgroundColor="NoChange">
        <highlight-condition foregroundColor="Red" backgroundColor="DarkRed">
          <text>ERROR</text>
        </highlight-condition>
      </highlight-row>

      <highlight-row foregroundColor="NoChange" backgroundColor="NoChange">
        <highlight-condition foregroundColor="Yellow" backgroundColor="NoChange">
          <text>WARN</text>
        </highlight-condition>
      </highlight-row>

      <highlight-row foregroundColor="NoChange" backgroundColor="NoChange">
        <highlight-condition foregroundColor="Green" backgroundColor="NoChange">
          <text>INFO</text>
        </highlight-condition>
      </highlight-row>

      <highlight-row foregroundColor="NoChange" backgroundColor="NoChange">
        <highlight-condition foregroundColor="DarkGray" backgroundColor="NoChange">
          <text>DEBUG</text>
        </highlight-condition>
      </highlight-row>
    </target>

    <!-- 所有日志文件 -->
    <target xsi:type="File"
            name="allFile"
            fileName="${logDirectory}/all-${shortdate}.log"
            layout="${layoutPattern}"
            archiveFileName="${logDirectory}/archive/all-{#}.log"
            archiveAboveSize="10485760"
            archiveNumbering="Rolling"
            maxArchiveFiles="30"
            concurrentWrites="true"
            keepFileOpen="false"
            encoding="utf-8" />

    <!-- 错误日志文件 -->
    <target xsi:type="File"
            name="errorFile"
            fileName="${logDirectory}/error-${shortdate}.log"
            layout="${layoutPattern}"
            archiveFileName="${logDirectory}/archive/error-{#}.log"
            archiveAboveSize="10485760"
            archiveNumbering="Rolling"
            maxArchiveFiles="90"
            concurrentWrites="true"
            keepFileOpen="false"
            encoding="utf-8" />

    <!-- 审计日志文件 - 单独记录审计事件 -->
    <target xsi:type="File"
            name="auditFile"
            fileName="${logDirectory}/audit-${shortdate}.log"
            layout="${longdate}|AUDIT|${logger:shortName=true}|${message}"
            archiveFileName="${logDirectory}/archive/audit-{#}.log"
            archiveAboveSize="10485760"
            archiveNumbering="Rolling"
            maxArchiveFiles="180"
            concurrentWrites="true"
            keepFileOpen="false"
            encoding="utf-8" />

    <!-- 性能日志文件 -->
    <target xsi:type="File"
            name="performanceFile"
            fileName="${logDirectory}/performance-${shortdate}.log"
            layout="${longdate}|PERF|${logger:shortName=true}|${message}"
            archiveFileName="${logDirectory}/archive/performance-{#}.log"
            archiveAboveSize="5242880"
            archiveNumbering="Rolling"
            maxArchiveFiles="14"
            concurrentWrites="true"
            keepFileOpen="false"
            encoding="utf-8" />

    <!-- API 请求日志文件 -->
    <target xsi:type="File"
            name="apiFile"
            fileName="${logDirectory}/api-${shortdate}.log"
            layout="${longdate}|${level:uppercase=true}|${aspnet-request-method}|${aspnet-request-url}|${message}"
            archiveFileName="${logDirectory}/archive/api-{#}.log"
            archiveAboveSize="10485760"
            archiveNumbering="Rolling"
            maxArchiveFiles="30"
            concurrentWrites="true"
            keepFileOpen="false"
            encoding="utf-8" />

    <!-- 结构化 JSON 日志 - 用于日志聚合系统（ELK、Splunk等）-->
    <target xsi:type="File"
            name="jsonFile"
            fileName="${logDirectory}/json-${shortdate}.log"
            archiveFileName="${logDirectory}/archive/json-{#}.log"
            archiveAboveSize="10485760"
            archiveNumbering="Rolling"
            maxArchiveFiles="30"
            concurrentWrites="true"
            keepFileOpen="false"
            encoding="utf-8">
      <layout xsi:type="JsonLayout" includeAllProperties="false" excludeProperties="excludeFromJson">
        <attribute name="timestamp" layout="${longdate}" />
        <attribute name="level" layout="${level:uppercase=true}" />
        <attribute name="logger" layout="${logger:shortName=true}" />
        <attribute name="message" layout="${message}" />
        <attribute name="exception" layout="${exception:format=ToString}" encode="false" />
        <attribute name="machinename" layout="${machinename}" />
        <attribute name="processid" layout="${processid}" />
        <attribute name="threadid" layout="${threadid}" />
        <attribute name="httpMethod" layout="${aspnet-request-method}" />
        <attribute name="httpUrl" layout="${aspnet-request-url}" />
        <attribute name="httpUserAgent" layout="${aspnet-request-useragent}" />
        <attribute name="httpUserId" layout="${aspnet-user-identity:property=name}" />
      </layout>
    </target>
  </targets>

  <!-- 定义规则 -->
  <rules>
    <!-- 跳过 Microsoft 框架的 Debug 日志 -->
    <logger name="Microsoft.*" level="Info" final="true" />

    <!-- 审计日志单独记录 - 包含 AUDIT 标记的日志 -->
    <logger name="Wms.Core.WebApi.Services.AuditLogService" minlevel="Info" writeTo="auditFile" final="false" />

    <!-- 性能日志单独记录 -->
    <logger name="Wms.Core.Performance.*" minlevel="Info" writeTo="performanceFile" final="true" />

    <!-- API 请求日志 -->
    <logger name="Wms.Core.WebApi" minlevel="Info" writeTo="apiFile" />

    <!-- 错误日志单独记录 -->
    <logger name="*" minlevel="Error" writeTo="errorFile" />

    <!-- 控制台输出 - 开发环境显示 Debug，生产环境显示 Info -->
    <logger name="*" minlevel="Info" writeTo="console" />

    <!-- 所有日志 -->
    <logger name="*" minlevel="Info" writeTo="allFile" />

    <!-- JSON 结构化日志 -->
    <logger name="*" minlevel="Info" writeTo="jsonFile" />
  </rules>
</nlog>
